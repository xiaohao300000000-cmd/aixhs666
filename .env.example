APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=education_demand
POSTGRES_USER=education_demand
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql+psycopg://education_demand:change_me@localhost:5432/education_demand

XHS_BROWSER_PROFILE_DIR=.runtime/xhs-profile
XHS_HEADLESS=false
XHS_SNAPSHOT_DIR=.runtime/snapshots
XHS_SCREENSHOT_DIR=.runtime/screenshots
XHS_PAGE_TIMEOUT_MS=30000
XHS_MANUAL_LOGIN_TIMEOUT_MS=120000
XHS_PROXY_SERVER=

WORKER_ID=worker-1
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_TASK_TIMEOUT_MINUTES=20
WORKER_SNAPSHOT_ROOT=.runtime/storage-snapshots
WORKER_ADAPTER=xiaohongshu
WORKER_PLATFORM=xhs
WORKER_LOG_LEVEL=INFO

MEDIACRAWLER_HOME=third_party/MediaCrawler
MEDIACRAWLER_PYTHON=third_party/MediaCrawler/.venv/bin/python
MEDIACRAWLER_OUTPUT_ROOT=.runtime/mediacrawler-runs
MEDIACRAWLER_LOG_DIR=.runtime/mediacrawler-logs
MEDIACRAWLER_LOGIN_TYPE=qrcode
MEDIACRAWLER_HEADLESS=false
MEDIACRAWLER_GET_COMMENTS=true
MEDIACRAWLER_GET_SUB_COMMENTS=false
MEDIACRAWLER_MAX_COMMENTS_PER_NOTE=3
MEDIACRAWLER_MAX_CONCURRENCY=1
MEDIACRAWLER_TIMEOUT_SECONDS=600
MEDIACRAWLER_ASSUME_HAS_MORE=false
MEDIACRAWLER_PROXY_SERVER=

FEISHU_ENABLED=false
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_TIMEOUT_SECONDS=10
FEISHU_MAX_RETRIES=2
